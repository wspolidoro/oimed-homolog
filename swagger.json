{
    "openapi": "3.0.1",
    "info": {
        "title": "OIMED",
        "description": "Bem-vindo à documentação da API OIMED, uma plataforma que fornece acesso a recursos e serviços essenciais para serviços de telemedicina. Esta documentação foi elaborada para orientar desenvolvedores, facilitando a integração e o entendimento completo das capacidades oferecidas pela nossa API.",
        "version": "1.0.1"
    },
    "servers": [
        {
            "url": "http://localhost:3035/api/sandbox",
            "description": "Development Server"
        },
        {
             "url": "https://parceiro.painelw.com.br/api/api",
            "description": "Production Server"
        }
    ],
    "basePath": "/",
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "paths": {
        "/auth?login={login}": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Rota para obter token de acesso, Atenção! para obter token de login adicione o valor true a queryParam Login",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "api_key": {
                                        "type": "string",
                                        "description": "Chave da API"
                                    },
                                    "secret_key": {
                                        "type": "string",
                                        "description": "Chave secreta"
                                    }
                                },
                                "required": [
                                    "api_key",
                                    "secret_key"
                                ]
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "in": "path",
                        "name": "login",
                        "type": "boolean",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "obter token de login",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                }
            }
        },
        "/consulta/oimed/{cpf}": {
            "get": {
                "tags": [
                    "Consulta"
                ],
                "summary": "Rota para consultar clientes ativos",
                "parameters": [
                    {
                        "in": "path",
                        "name": "cpf",
                        "type": "string",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "cpf do cliente"
                        }
                    }
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                }
            }
        },
