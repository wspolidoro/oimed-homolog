        "/franqueado/clientes": {
            "post": {
                "tags": [
                    "Ações"
                ],
                "summary": "Rota para criar um usuário na base de dados",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "nm_cliente": {
                                        "type": "string",
                                        "description": "nome do usuario",
                                        "example": "João Silva"
                                    },
                                    "nu_documento": {
                                        "type": "string",
                                        "description": "CPF do usuário",
                                        "example": "123.456.789-00"
                                    },
                                    "birthday": {
                                        "type": "string",
                                        "description": "data de nascimento do usuário",
                                        "example": "01/01/2000"
                                    },
                                    "telefone": {
                                        "type": "string",
                                        "description": "telefone do usuário",
                                        "example": "11987654321"
                                    },
                                    "email": {
                                        "type": "string",
                                        "description": "email do usuário",
                                        "example": "joao.silva@example.com"
                                    },
                                    "zip_code": {
                                        "type": "string",
                                        "description": "cep do usuário",
                                        "example": "12345-678"
                                    },
                                    "address": {
                                        "type": "string",
                                        "description": "endereço do usuário",
                                        "example": "Rua das Flores, 123"
                                    },
                                    "city": {
                                        "type": "string",
                                        "description": "cidade do usuário",
                                        "example": "São Paulo"
                                    },
                                    "state": {
                                        "type": "string",
                                        "description": "uf do usuário",
                                        "example": "SP"
                                    },
                                    "serviceType": {
                                        "type": "string",
                                        "description": "tipo serviço do usuário padrão {G}",
                                        "default": "GSP"
                                    },
                                    "cpfTitular": {
                                        "type": "string",
                                        "description": "cpf do titular, se for um dependente. se não for um dependente repetir o nu_documento"
                                    },
                                    "idParceiro": {
                                        "type": "string",
                                        "description": "id do parceiro, se for um dependente. se não for um dependente repetir o nu_documento"
                                    }
                                },
                                "required": [
                                    "nm_cliente",
                                    "nu_documento",
                                    "idParceiro"
                                ]
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                },
                "description": "**-serviceType aceita** \n- \"G\" (clínico),\n- \"P\" (psicologia),\n- \"GP\" (clínico + psicologia),\n- \"GS\" (clínico + especialista),\n- \"GSP\" (clínico + especialistas + psicologia )\n- default \"G\";"
            }
        },
        "/beneficiaries/dependente": {
            "post": {
                "tags": [
                    "Ações"
                ],
                "summary": "Rota para criar um dependente na base de dados",
                "requestBody": {
