                                    },
                                    "telefone": {
                                        "type": "string",
                                        "description": "telefone do usuário"
                                    },
                                    "email": {
                                        "type": "string",
                                        "description": "email do usuário"
                                    },
                                    "zip_code": {
                                        "type": "string",
                                        "description": "cep do usuário"
                                    },
                                    "address": {
                                        "type": "string",
                                        "description": "endereço do usuário"
                                    },
                                    "city": {
                                        "type": "string",
                                        "description": "cidade do usuário"
                                    },
                                    "state": {
                                        "type": "string",
                                        "description": "uf do usuário"
                                    },
                                    "cpfTitular": {
                                        "type": "string",
                                        "description": "cpf do titular, se for um dependente. se não for um dependente repetir o nu_documento"
                                    }
                                },
                                "required": [
                                    "nm_cliente",
                                    "nu_documento",
                                    "cpfTitular"
                                ]
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                }
            }
        },
        "/beneficiaries/edit/{cpf}": {
            "put": {
                "tags": [
                    "Ações"
                ],
                "summary": "Rota para atualizar dados de clientes, enviar apenas os campos que deseja atualizar",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "nm_cliente": {
                                        "type": "string",
                                        "description": "nome do usuario",
                                        "example": "João Silva"
                                    },
                                    "nu_documento": {
                                        "type": "string",
                                        "description": "CPF do usuário"
                                    },
                                    "birthday": {
                                        "type": "string",
                                        "description": "data de nascimento do usuário"
                                    },
                                    "telefone": {
                                        "type": "string",
                                        "description": "telefone do usuário"
                                    },
                                    "email": {
                                        "type": "string",
                                        "description": "email do usuário"
                                    },
                                    "zip_code": {
                                        "type": "string",
                                        "description": "cep do usuário"
                                    },
                                    "address": {
                                        "type": "string",
                                        "description": "endereço do usuário"
                                    },
                                    "city": {
                                        "type": "string",
                                        "description": "cidade do usuário"
                                    },
                                    "state": {
                                        "type": "string",
                                        "description": "uf do usuário"
                                    },
                                    "serviceType": {
                                        "type": "string",
                                        "description": "tipo de plano do usuário",
                                        "default": "G"
                                    }
                                },
                                "required": [
                                    "api_key",
                                    "secret_key"
                                ]
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "in": "path",
                        "name": "cpf",
                        "type": "string",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "cpf do cliente (Apenas numeros)",
                            "default": "12345678910"
                        }
                    }
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                },
                "description": "**-serviceType aceita** \n- \"G\" (clínico),\n- \"P\" (psicologia),\n- \"GP\" (clínico + psicologia),\n- \"GS\" (clínico + especialista),\n- \"GSP\" (clínico + especialistas + psicologia )\n- default \"G\";\n\n**Envie apenas os campos que deseja atualizar.**"
            }
        },
        "/oimed/specialties": {
            "get": {
                "tags": [
                    "Agendamento"
                ],
                "summary": "Rota para consultar especialidades",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                },
                "description": "Este endpoint realiza uma busca no banco de dados para listar todas as especialidades médicas ou de serviço que estão ativas e disponíveis para agendamento ou visualização."
            }
        },
        "/oimed/specialty-availability": {
            "post": {
                "tags": [
                    "Agendamento"
                ],
                "summary": "Rota para consultar disponibilidade por especialidade",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "dateInitial": {
                                        "type": "string",
                                        "description": "Data inicial do período de busca (formato: DD/MM/YYYY)"
                                    },
                                    "dateFinal": {
                                        "type": "string",
                                        "description": "Data final do período de busca (formato: DD/MM/YYYY)"
                                    },
                                    "specialtyUuid": {
                                        "type": "string",
                                        "description": "UUID da especialidade médica ou de serviço"
                                    },
                                    "beneficiaryUuid": {
                                        "type": "string",
                                        "description": "cpf do cliente (Apenas numeros)"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                },
                "description": "Lista todos os horários disponíveis em dado período, para determinada especialidade.\n\n**Parâmetros obrigatórios:**\n- dateInitial: Data inicial do período de busca (formato: DD/MM/YYYY)\n- dateFinal: Data final do período de busca (formato: DD/MM/YYYY)\n- specialtyUuid: UUID da especialidade médica ou de serviço \n- beneficiaryUuid: cpf do cliente**"
            }
        },
        "/oimed/appointments": {
            "post": {
                "tags": [
                    "Agendamento"
                ],
                "summary": "Rota para criar agendamentos",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "beneficiaryUuid": {
                                        "type": "string",
                                        "description": "cpf do cliente (Apenas numeros)"
                                    },
                                    "availabilityUuid": {
                                        "type": "string",
                                        "description": "UUID da disponibilidade"
                                    },
                                    "specialtyUuid": {
                                        "type": "string",
                                        "description": "UUID da especialidade médica ou de serviço"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Bad request"
                    },
                    "404": {
                        "description": "Error: Not Found"
                    },
                    "500": {
                        "description": "Erro interno"
                    }
                },
                "description": "Criar um agendamento para determinada especialidade.\n\n**Parâmetros obrigatórios:**\n- availabilityUuid: UUID da disponibilidade\n- specialtyUuid: UUID da especialidade médica ou de serviço \n- beneficiaryUuid: cpf do cliente**"
            }
        },
